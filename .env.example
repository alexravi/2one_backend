# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=2one_db

# Authentication
JWT_SECRET=super_secret_jwt_key_here
JWT_EXPIRES_IN=1d

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT_NAME;AccountKey=YOUR_ACCOUNT_KEY;EndpointSuffix=core.windows.net"
AZURE_STORAGE_CONTAINER_NAME=recordings

# Azure Service Bus (using Topics for pub/sub)
AZURE_SERVICE_BUS_CONNECTION_STRING="Endpoint=sb://YOUR_NAMESPACE.servicebus.windows.net/;SharedAccessKeyName=YOUR_KEY_NAME;SharedAccessKey=YOUR_KEY"
AZURE_SERVICE_BUS_TOPIC_NAME=processing-topic
# Subscription name (used by the worker to receive from the topic)
AZURE_SERVICE_BUS_SUBSCRIPTION_NAME=worker-subscription
